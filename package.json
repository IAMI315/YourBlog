    "@types/yazl": "3.3.1",
    "dependency-cruiser": "18.0.0",
    "eslint": "10.6.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "prisma": "7.8.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yazl": "3.3.1"

    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "argon2": "0.44.0",
    "lucide-react": "1.24.0",
    "nanoid": "5.1.16",
    "next": "16.2.10",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "sharp": "0.35.3",
